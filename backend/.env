# Backend .env (copy from .env.example and customize)
APP_NAME=ShieldSpeak
APP_ENV=development
APP_SECRET_KEY=dev-secret-key-change-in-production-to-random-string
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7
DATABASE_URL=sqlite:///./shieldspeak.db
REDIS_URL=redis://localhost:6379/0
CORS_ORIGINS=http://localhost:3000
MODEL_NAME_TEXT_CLASSIFIER=unitary/toxic-bert
WHISPER_MODEL_SIZE=base
MAX_AUDIO_UPLOAD_MB=25
